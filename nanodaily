#!/bin/bash
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT" || exit 1

echo "═══════════════════════════════════════════════"
echo "           NANODAILY HEALTH — $(date '+%Y-%m-%d %H:%M')"
echo "═══════════════════════════════════════════════"
echo "💰 BALANCE:"
REPORT_OUTPUT="$(PYTHONIOENCODING=utf-8 python scripts/pnl_report.py 2>/dev/null || true)"
DAILY_BALANCE_VIEW="$(
  printf '%s\n' "$REPORT_OUTPUT" | awk '
    /^💰 CURRENT BALANCE/ {print; in_balance=1; next}
    in_balance {
      print
      if ($0 ~ /^[[:space:]]*$/) {in_balance=0}
      next
    }
    /^📊 PNL SNAPSHOT/ {print; pnl_left=4; next}
    pnl_left > 0 {print; pnl_left--; next}
  '
)"
if [ -n "${DAILY_BALANCE_VIEW//[[:space:]]/}" ]; then
  printf '%s\n' "$DAILY_BALANCE_VIEW"
else
  # Backward-compatible fallback for minimal/stub pnl_report output.
  printf '%s\n' "$REPORT_OUTPUT" | grep -E "(CURRENT BALANCE|source:|USDC|WMATIC|USDT|TOTAL|Since baseline|Session PnL|24h PnL)"
fi
echo ""
echo "📊 TODAY STATS:"
echo "Small trades bypassed: $(grep -c 'HARD BYPASS' real_cron.log 2>/dev/null || echo 0)"
echo "Cooldown skips: $(grep -c 'skip cycle' real_cron.log 2>/dev/null || echo 0)"
echo "Protection triggers: $(grep -c 'TRADE SKIPPED' real_cron.log 2>/dev/null || echo 0)"
echo ""
echo "🔧 SYSTEM:"
echo "Commit: $(git rev-parse --short HEAD)"
echo "Test Mode: $(grep TEST_MODE .env || echo 'not set')"
echo "═══════════════════════════════════════════════"
