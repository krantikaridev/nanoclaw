#!/bin/bash
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$ROOT" || exit 1

echo "═══════════════════════════════════════════════"
echo "           NANODAILY HEALTH — $(date '+%Y-%m-%d %H:%M')"
echo "═══════════════════════════════════════════════"
echo "💰 BALANCE:"
REPORT_OUTPUT="$(PYTHONIOENCODING=utf-8 python scripts/pnl_report.py --daily-summary 2>&1)"
SUMMARY_EXIT=$?
if [ "$SUMMARY_EXIT" -eq 0 ] && [ -n "${REPORT_OUTPUT//[[:space:]]/}" ]; then
  printf '%s\n' "$REPORT_OUTPUT"
else
  # Fallback when --daily-summary fails or emits no usable output.
  echo "⚠️ daily-summary fallback (exit=$SUMMARY_EXIT)"
  REPORT_OUTPUT="$(PYTHONIOENCODING=utf-8 python scripts/pnl_report.py 2>&1 || true)"
  printf '%s\n' "$REPORT_OUTPUT" | grep -E "(CURRENT BALANCE|source:|Stables USDC|USDC|WMATIC|USDT|TOTAL|suspect|Since baseline|Session PnL|24h PnL)"
fi
echo ""
echo "📊 TODAY STATS:"
echo "Small trades bypassed: $(grep -c 'HARD BYPASS' real_cron.log 2>/dev/null || echo 0)"
echo "Cooldown skips: $(grep -c 'skip cycle' real_cron.log 2>/dev/null || echo 0)"
echo "Protection triggers: $(grep -c 'TRADE SKIPPED' real_cron.log 2>/dev/null || echo 0)"
echo ""
echo "🔧 SYSTEM:"
echo "Commit: $(git rev-parse --short HEAD)"
echo "Test Mode: $(grep TEST_MODE .env || echo 'not set')"
echo "═══════════════════════════════════════════════"
