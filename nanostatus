#!/bin/bash
echo "═══════════════════════════════════════════════════════════════"
echo "           NANOSTATUS v2.9 — Daily Operator Snapshot"
echo "═══════════════════════════════════════════════════════════════"
echo "Time: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo ""

# === Clean Top Summary (most important for PnL > 0) ===
SESSION_PNL=$(nanopnl | awk '/Session PnL:/ {print $3" "$4; exit}' || echo "N/A")
TOTAL=$(nanopnl | awk '/TOTAL:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
USDC_RT=$(nanopnl | awk '/USDC:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
USDT_RT=$(nanopnl | awk '/USDT:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")

echo "SESSION PnL: $SESSION_PNL     |     Total: \$$TOTAL"
echo "USDC: \$$USDC_RT     |     USDT: \$$USDT_RT"
echo ""
echo "BASELINE: Clean performance tracking since 07:01 reset (does NOT include the $50 top-up)."
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "1. Health"
nanohealth
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "2. Recent Performance (1h lookback)"
nanodaily --lookback 1h | grep -E "(Stables USD|TOTAL:|Session PnL:|1h ref)" | head -6
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "3. On-chain vs Runtime (Risk & Divergence)"
./nanoreconcile
echo ""

echo "═══════════════════════════════════════════════════════════════"
echo "Goal: Keep Session PnL > 0 | Run daily"
