#!/bin/bash
echo "=== NanoStatus v2.9 (daily operator snapshot) ==="
echo "Time: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo ""

# Quick one-line summary
USDC_RT=$(nanopnl | awk '/USDC:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
USDT_RT=$(nanopnl | awk '/USDT:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
TOTAL=$(nanopnl | awk '/TOTAL:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
SESSION_PNL=$(nanopnl | awk '/Session PnL:/ {print $3, $4; exit}' || echo "N/A")

echo "SUMMARY: Total $TOTAL | Session $SESSION_PNL | USDC $USDC_RT | USDT $USDT_RT"
echo ""

echo "1. Health"
nanohealth
echo ""

echo "2. 1h PnL + Lookback"
nanodaily --lookback 1h
nanopnl
echo ""

echo "3. On-chain vs Runtime Reconciliation"
./nanoreconcile
echo ""

echo "Done. Run daily during office hours."
