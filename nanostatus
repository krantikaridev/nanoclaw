#!/bin/bash
echo "═══════════════════════════════════════════════════════════════"
echo "           NANOSTATUS v2.9 — Daily Operator Snapshot"
echo "═══════════════════════════════════════════════════════════════"
echo "Time: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo ""

USDC_RT=$(nanopnl | awk '/USDC:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
USDT_RT=$(nanopnl | awk '/USDT:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
TOTAL=$(nanopnl | awk '/TOTAL:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
SESSION=$(nanopnl | awk '/Session PnL:/ {print $3" "$4; exit}' || echo "N/A")

echo "SUMMARY → Total: \$$TOTAL | Session: $SESSION | USDC: \$$USDC_RT | USDT: \$$USDT_RT"
echo ""
echo "NOTE: Session PnL is clean since last manual reset (07:01 today)."
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "1. Health"
nanohealth
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "2. PnL + Lookback"
nanodaily --lookback 1h | head -25
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "3. On-chain Reconciliation + Risk"
./nanoreconcile
echo ""

echo "═══════════════════════════════════════════════════════════════"
echo "Done. Run daily during office hours."
