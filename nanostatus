#!/bin/bash
echo "═══════════════════════════════════════════════════════════════"
echo "           NANOSTATUS v2.9 — Daily Operator Snapshot"
echo "═══════════════════════════════════════════════════════════════"
echo "Time: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo ""

# Clean top summary
USDC_RT=$(nanopnl | awk '/USDC:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
USDT_RT=$(nanopnl | awk '/USDT:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
TOTAL=$(nanopnl | awk '/TOTAL:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
SESSION=$(nanopnl | awk '/Session PnL:/ {print $3" "$4; exit}' || echo "N/A")

echo "SUMMARY → Total: \$$TOTAL | Session: $SESSION | USDC: \$$USDC_RT | USDT: \$$USDT_RT"
echo ""
echo "BASELINE: Performance since last manual reset (currently 07:01 today)."
echo "          'Since baseline' includes all activity after that reset."
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "1. Health"
nanohealth
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "2. PnL + Multi Lookback (progress check)"
echo ""

# 1h
echo ">>> 1h Lookback"
nanodaily --lookback 1h | grep -E "(Stables|TOTAL:|Session PnL:|Since baseline:|1h ref|4h ref)" | head -8
echo ""

# 2h
echo ">>> 2h Lookback"
nanodaily --lookback 2h | grep -E "(TOTAL:|Session PnL:|Since baseline:|2h ref)" | head -5
echo ""

# 4h
echo ">>> 4h Lookback"
nanodaily --lookback 4h | grep -E "(TOTAL:|Session PnL:|Since baseline:|4h ref)" | head -5
echo ""

# 6h (if data exists)
echo ">>> 6h Lookback"
nanodaily --lookback 6h 2>/dev/null | grep -E "(TOTAL:|Session PnL:|Since baseline:|6h ref)" | head -5 || echo "Not enough history yet"
echo ""

echo "───────────────────────────────────────────────────────────────"
echo "3. On-chain Reconciliation + Risk"
./nanoreconcile
echo ""

echo "═══════════════════════════════════════════════════════════════"
echo "Goal: Keep Session PnL > 0 | Run daily during office hours."
