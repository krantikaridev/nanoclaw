# --- Environment files ---
# Ignore secret and machine-specific env files. Allow only committed templates:
#   tracked: .env.example, .env.sample
# Git applies the last matching rule per path; `!` entries must appear after `.env.*`.
.env
.env.*
!.env.example
!.env.sample

*.backup*

# Virtual environment
.venv/
venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Coverage (coverage.py / pytest-cov; never commit)
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/

# Runtime files (we commit these manually)
!portfolio_history.csv
!real_cron.log

# OS & editor
.DS_Store
.vscode/
.idea/
*.swp

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Runtime files (never commit)
bot_state.json
portfolio_history.csv
real_cron.log
__pycache__/
*.pyc
*.log

# Bot runtime files (never commit)
portfolio_history.csv
real_cron.log
*.log

# NanoClaw aliases
scripts/nanobot_aliases.sh
