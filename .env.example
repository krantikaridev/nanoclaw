# =============================================================================
# Nanoclaw — example environment (safe to commit). Copy to `.env` and fill secrets.
# =============================================================================
#
# Conventions (reduces corruption when tools append lines):
#   1) Secrets / keys in the first block only.
#   2) Append new non-secret tuning at the BOTTOM.
#   3) One primary JSON-RPC: set `RPC=` (used first by `nanoclaw.config.default_json_rpc_url`).
#      You may also set `RPC_URL` / `WEB3_PROVIDER_URI` — use the SAME host as `RPC` unless
#      you intend multi-endpoint fallback (conflicting hosts caused bad behavior in 2026-05).
#
# Grok / stage policy (2026-05-03) — use these **exact key names** (code does not read Grok aliases):
#   COPY_TRADE_PCT=0.28   TAKE_PROFIT_PCT=5.0   STRONG_SIGNAL_TP=12.0
#   X_SIGNAL_STRONG_THRESHOLD=0.80   X_SIGNAL_FORCE_*_THRESHOLD=0.80
#   Fixed $12–$20 per-signal sizing is enforced in code (`fixed_copy_trade_usd` + COPY_TRADE_PCT), not by
#   COPY_TRADE_SIZE_USD / MAX_TRADE_SIZE_USD (those names are not read by the bot).
#
# Sync from a live VM `.env` without secrets:
#   python scripts/nanoenv_example.py --write
#   git diff .env.example   # always review before commit
#
# =============================================================================

# --- Secrets (never commit real values) ---
POLYGON_PRIVATE_KEY=
PRIVATE_KEY=

# Optional observability (modules/agent_layer.py) — leave empty to disable.
NANOCLAW_GROK_ENABLED=false
GROK_API_KEY=
XAI_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-2-latest
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional 1inch quotes (swap_executor.py)
ONEINCH_API_KEY=
INCH_API_KEY=

# --- RPC (`nanoclaw.config.connect_web3`: RPC → RPC_URL → WEB3_PROVIDER_URI → fallbacks) ---
RPC=https://rpc.ankr.com/polygon
RPC_URL=https://rpc.ankr.com/polygon
WEB3_PROVIDER_URI=https://polygon.llamarpc.com
RPC_FALLBACKS=

# --- Public wallet & Polygon contracts ---
WALLET=0x6e291a7180bD198d67Eeb792Bb3262324D3e64AA
USDT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDC=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
WMATIC=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
ROUTER=0xa5E0829CaCEd8fFDD4De3c43696c57F7D7A678ff

LOG_PREFIX=[nanoclaw]

# --- ABI paths (optional; defaults are in-repo) ---
ERC20_ABI_PATH=nanoclaw/abi/erc20.json
ROUTER_ABI_PATH=nanoclaw/abi/router_swap_exact_tokens_for_tokens.json
GET_AMOUNTS_OUT_ABI_PATH=nanoclaw/abi/router_get_amounts_out.json

# --- Gas & POL ---
POL_USD_PRICE=0.10
MIN_POL_FOR_GAS=0.005
AUTO_TOPUP_POL=true
POL_TOPUP_AMOUNT=0.03
MAX_GWEI=80
URGENT_GWEI=120
GAS_RPC_RETRY_ATTEMPTS=2

# --- Global timing (Grok “180s” global cooldown → minutes) ---
COOLDOWN_MINUTES=3
PER_ASSET_COOLDOWN_MINUTES=30

# --- Copy / main strategy levers (stage policy) ---
COPY_TRADING_ENABLED=true
COPY_TRADE_PCT=0.28
PER_WALLET_COOLDOWN=180

# --- Take-profit & exits ---
TRAILING_STOP_PCT=5.0
TAKE_PROFIT_PCT=5.0
STRONG_SIGNAL_TP=12.0
TAKE_PROFIT_SELL_PCT=0.45
STRONG_TP_SELL_PCT=0.60

# --- USDC copy strategy ---
ENABLE_USDC_COPY=true
USDC_COPY_MIN_TRADE=5.0
USDC_COPY_MAX_TRADE=15.0

# --- X-Signal equity ---
ENABLE_X_SIGNAL_EQUITY=true
FOLLOWED_EQUITIES_PATH=followed_equities.json
X_SIGNAL_EQUITY_MIN_STRENGTH=0.60
X_SIGNAL_STRONG_THRESHOLD=0.80
X_SIGNAL_MAX_EARNINGS_DAYS=5.0
X_SIGNAL_FORCE_ELIGIBLE_THRESHOLD=0.80
X_SIGNAL_FORCE_HIGH_CONVICTION_THRESHOLD=0.80
X_SIGNAL_FORCE_HIGH_CONVICTION=true
X_SIGNAL_HIGH_CONVICTION_PREP_MIN_USDC=8.0
X_SIGNAL_HIGH_CONVICTION_PREP_MIN_WMATIC=12.0
X_SIGNAL_DYNAMIC_TIER_HIGH_MIN=0.90
X_SIGNAL_DYNAMIC_USDC_GTE_TIER_HIGH=20.0
X_SIGNAL_DYNAMIC_USDC_GTE_FORCE_ELIGIBLE=15.0
X_SIGNAL_DYNAMIC_USDC_BELOW_FORCE_ELIGIBLE=12.0
X_SIGNAL_EQUITY_COOLDOWN_FIRST_SORT=true
X_SIGNAL_EQUITY_STRONG_TP_PCT=12.0
X_SIGNAL_EQUITY_TRADE_PCT=0.18
X_SIGNAL_EQUITY_MAX_TRADE=28.0
X_SIGNAL_USDC_MIN=5.0
X_SIGNAL_WMATIC_MIN_VALUE=15.0
AUTO_POPULATE_USDC_AMOUNT=20.0
AUTO_USDC_FOR_X_SIGNAL_MIN_USDC=5.0
AUTO_USDC_FOR_X_SIGNAL_MIN_WMATIC_VALUE=15.0
X_SIGNAL_USDC_SAFE_FLOOR=20.0
X_SIGNAL_AUTO_USDC_TARGET=25.0

# --- Swaps ---
SWAP_SLIPPAGE_BPS=100

# --- Logging hooks ---
NANOCLAW_TRADE_ATTRIBUTION=true

# --- PnL baseline for nanomon (optional) ---
PORTFOLIO_BASELINE_USD=

# =============================================================================
# Append new tuning here (agents / brainstorm): non-secret keys only.
# =============================================================================

# --- Fixed per-signal USD band (runtime.fixed_copy_trade_usd) ---
FIXED_TRADE_USD_MIN=12
FIXED_TRADE_USD_MAX=20

# --- WMATIC↔USDT main strategy (modules.swap_executor.select_main_strategy_trade) ---
MAIN_STRATEGY_MIN_USDT_RESERVE=25
MAIN_STRATEGY_TP_TRIGGER_WMATIC_USD=52
MAIN_STRATEGY_CUT_LOSS_WMATIC_USD=40
MAIN_STRATEGY_CUT_LOSS_MIN_WMATIC_BALANCE=50
MAIN_STRATEGY_RESERVE_SELL_FRACTION=0.45
MAIN_STRATEGY_CUT_LOSS_SELL_FRACTION=0.28

# --- Aggressive copy-trade banner when COPY_TRADE_PCT is high ---
COPY_TRADE_AGGRESSIVE_THRESHOLD=0.20

# --- protection.py (no wallet secrets) ---
PROTECTION_MAX_DAILY_LOSS_PCT=15
PROTECTION_MIN_POL_BALANCE=2.0
PROTECTION_MAX_TRADE_SIZE_USD=35
PROTECTION_GAS_MULTIPLIER=1.25
PROTECTION_FLUCTUATION_USDT_THRESHOLD=30
PROTECTION_FLUCTUATION_MIN_WMATIC=50
PROTECTION_FLUCTUATION_SELL_FRACTION=0.25
PROTECTION_PROFIT_LOCK_PERCENT=8

# --- copy_trading.py default when followed_wallets.json is missing ---
DEFAULT_MAX_COPY_RATIO=0.20

# --- Optional: comma-separated addresses treated as wrong-chain in diagnostics (modules.signal) ---
# CHAIN_HINT_WRONG_ETH_ADDRESSES=
