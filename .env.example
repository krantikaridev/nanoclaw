# Example environment configuration for Nanoclaw (safe to commit).
#
# Copy to `.env` locally and fill in secrets outside git.

# Structured prefix on actionable log lines (`clean_swap`, `swap_executor`).
LOG_PREFIX=[nanoclaw]

# === Addresses (Polygon) ===
WALLET=0x6e291a7180bD198d67Eeb792Bb3262324D3e64AA
USDT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDC=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
WMATIC=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
ROUTER=0xa5E0829CaCEd8fFDD4De3c43696c57F7D7A678ff

# === ABI paths (optional overrides; defaults are in-repo) ===
ERC20_ABI_PATH=nanoclaw/abi/erc20.json
ROUTER_ABI_PATH=nanoclaw/abi/router_swap_exact_tokens_for_tokens.json
GET_AMOUNTS_OUT_ABI_PATH=nanoclaw/abi/router_get_amounts_out.json

# === RPC ===
RPC=https://polygon.publicnode.com
RPC_FALLBACKS=

# === Runtime / Risk Settings ===
COOLDOWN_MINUTES=7
PER_ASSET_COOLDOWN_MINUTES=30
# Native POL USD price used for portfolio history valuation.
# Keep this updated if you want tighter CSV accounting.
POL_USD_PRICE=0.10
MIN_POL_FOR_GAS=0.005
AUTO_TOPUP_POL=true
POL_TOPUP_AMOUNT=0.03
MAX_GWEI=80
URGENT_GWEI=120
GAS_RPC_RETRY_ATTEMPTS=2

# === Strategy Settings ===
COPY_TRADE_PCT=0.25
PER_WALLET_COOLDOWN=180
TRAILING_STOP_PCT=5.0
TAKE_PROFIT_PCT=8.0
STRONG_SIGNAL_TP=12.0
TAKE_PROFIT_SELL_PCT=0.45
STRONG_TP_SELL_PCT=0.60
X_SIGNAL_EQUITY_STRONG_TP_PCT=12.0

# === Feature Flags ===
COPY_TRADING_ENABLED=true
ENABLE_USDC_COPY=true
ENABLE_X_SIGNAL_EQUITY=false
X_SIGNAL_EQUITY_MIN_STRENGTH=0.60

# Minimum abs(signal_strength) to open a trade in SignalEquityTrader.build_plan (separate from eligibility floor above).
X_SIGNAL_STRONG_THRESHOLD=0.80
X_SIGNAL_MAX_EARNINGS_DAYS=5.0
# abs(signal) >= this bypasses earnings/cooldown/gas/strength bar in build_plan (default aligns with high-conviction threshold).
X_SIGNAL_FORCE_ELIGIBLE_THRESHOLD=0.80
X_SIGNAL_FORCE_HIGH_CONVICTION_THRESHOLD=0.80
X_SIGNAL_FORCE_HIGH_CONVICTION=true
# High-conviction prep (ensure_usdc) before building plans when any eligible signal is at/above high-conviction threshold.
X_SIGNAL_HIGH_CONVICTION_PREP_MIN_USDC=8.0
X_SIGNAL_HIGH_CONVICTION_PREP_MIN_WMATIC=12.0
# BUY notionals by tier (defaults match nanoclaw.config.X_SIGNAL; abs signal vs TIER_HIGH_MIN and force-eligible threshold).
X_SIGNAL_DYNAMIC_TIER_HIGH_MIN=0.90
X_SIGNAL_DYNAMIC_USDC_GTE_TIER_HIGH=20.0
X_SIGNAL_DYNAMIC_USDC_GTE_FORCE_ELIGIBLE=15.0
X_SIGNAL_DYNAMIC_USDC_BELOW_FORCE_ELIGIBLE=12.0
# Prefer assets off per-asset cooldown before higher-signal assets still cooling down (reduces single-symbol starvation).
X_SIGNAL_EQUITY_COOLDOWN_FIRST_SORT=true

# X-Signal: iron-fenced USDC population + dust guards.
# - WMATIC→USDC is the strong default (gas optimized); only fallback to USDT→USDC if WMATIC is insufficient.
# - If strong BUY and USDC < X_SIGNAL_USDC_MIN, bot will force auto-population; if still < min trade it skips BUY.
X_SIGNAL_USDC_MIN=5.0
X_SIGNAL_WMATIC_MIN_VALUE=15.0
AUTO_POPULATE_USDC_AMOUNT=20.0

# Back-compat (older variable names; safe to omit if using the new ones above)
AUTO_USDC_FOR_X_SIGNAL_MIN_USDC=5.0
AUTO_USDC_FOR_X_SIGNAL_MIN_WMATIC_VALUE=15.0

# Proactive USDC maintenance for X-Signal equity trading.
# If USDC drops below this threshold, proactively top-up to X_SIGNAL_AUTO_USDC_TARGET.
X_SIGNAL_USDC_SAFE_FLOOR=20.0
# Target USDC amount when proactive top-up is triggered.
X_SIGNAL_AUTO_USDC_TARGET=25.0

# Uniswap-V2-style router: quote min-out max slippage (basis points, 100 = 1%).
SWAP_SLIPPAGE_BPS=100

# === Optional tuning for USDC copy ===
USDC_COPY_MIN_TRADE=5.0
USDC_COPY_MAX_TRADE=15.0

# === Secrets (do not commit real values) ===
POLYGON_PRIVATE_KEY=

