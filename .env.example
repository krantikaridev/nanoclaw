# =============================================================================
# Nanoclaw — example environment (safe to commit). Copy to `.env` and fill secrets.
# =============================================================================
#
# Conventions (reduces merge corruption when tools append lines):
#   1) Secrets / keys only in the secrets block below (leave values blank here).
#   2) Prefer adding new non-secret tuning at the BOTTOM block marked “Append”.
#   3) RPC policy and ROI baseline: see docs/ENV_RPC.md
#
# Grok / stage policy — prefer these exact key names.
# Some legacy aliases are still read for backward compatibility and are documented below.
#   COPY_TRADE_PCT=0.28   TAKE_PROFIT_PCT=5.0   STRONG_SIGNAL_TP=12.0
#   X_SIGNAL_STRONG_THRESHOLD=0.80   X_SIGNAL_FORCE_*_THRESHOLD=0.80
#   Fixed $12–$20 per-signal sizing: runtime.fixed_copy_trade_usd (+ COPY_TRADE_PCT), not
#   COPY_TRADE_SIZE_USD / MAX_TRADE_SIZE_USD (those names are not read).
#
# Sync from a live VM `.env` without secrets (review diff before commit):
#   python scripts/nanoenv_example.py --write
#   git diff .env.example
# Verify template drift + config coverage:
#   python scripts/verify_env_example_keys.py
#
# =============================================================================

# --- Secrets (never commit real values) ---
# Wallet signing key (preferred: POLYGON_PRIVATE_KEY).
# Legacy alias PRIVATE_KEY is still read as fallback for backward compatibility.
POLYGON_PRIVATE_KEY=
PRIVATE_KEY=

# --- Optional integrations (empty value = feature off unless noted) ---
NANOCLAW_GROK_ENABLED=false
GROK_API_KEY=
XAI_API_KEY=
GROK_API_BASE=https://api.x.ai/v1
GROK_MODEL=grok-2-latest
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional 1inch quotes (swap_executor) ---
ONEINCH_API_KEY=
INCH_API_KEY=

# --- RPC (details: docs/ENV_RPC.md) ---
# Primary = first set among RPC → RPC_URL → WEB3_PROVIDER_URI; then built-in public Polygon URLs.
# Recommended: set RPC and RPC_URL to the SAME URL; use WEB3_PROVIDER_URI only if a tool requires it.
RPC=https://rpc.ankr.com/polygon
RPC_URL=https://rpc.ankr.com/polygon
WEB3_PROVIDER_URI=https://rpc.ankr.com/polygon
# Extra endpoints for gas/POL fallback probing only (comma-separated). Empty = no extras beyond default chain.
RPC_FALLBACKS=

# --- Public wallet & Polygon contracts ---
WALLET=0x05eF62F48Cf339AA003F1a42E4CbD622FFa1FBe6
USDT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
USDC=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDC_NATIVE=
WMATIC=0x0d500B1d8E8eF31E21C99d1Db9A6444d3ADf1270
ROUTER=0xa5E0829CaCEd8fFDD4De3c43696c57F7D7A678ff
QUICKSWAP_V2_ROUTER=0xa5E0829CaCEd8fFDD4De3c43696c57F7D7A678ff
UNISWAP_V3_SWAP_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
UNISWAP_V3_QUOTER=0xb27308f9F90D607463bb33eA1BeBb41C27CE5AB6

LOG_PREFIX=[nanoclaw]

# --- ABI paths (defaults are in-repo) ---
ERC20_ABI_PATH=nanoclaw/abi/erc20.json
ROUTER_ABI_PATH=nanoclaw/abi/router_swap_exact_tokens_for_tokens.json
GET_AMOUNTS_OUT_ABI_PATH=nanoclaw/abi/router_get_amounts_out.json

# --- Gas & POL ---
POL_USD_PRICE=0.10
MIN_POL_FOR_GAS=0.005
AUTO_TOPUP_POL=true
POL_TOPUP_AMOUNT=0.03
MAX_GWEI=80
URGENT_GWEI=120
GAS_RPC_RETRY_ATTEMPTS=2

# --- Global timing (Grok “180s” global cooldown → minutes) ---
# Stage VM currently may use: COOLDOWN_MINUTES=2
COOLDOWN_MINUTES=3
PER_ASSET_COOLDOWN_MINUTES=30
TEST_MODE=true

# --- Copy / main strategy levers (stage policy) ---
COPY_TRADING_ENABLED=true
COPY_TRADE_PCT=0.20
COPY_RATIO=0.20
PER_WALLET_COOLDOWN=180

# --- Take-profit & exits ---
TRAILING_STOP_PCT=5.0
TAKE_PROFIT_PCT=5.0
STRONG_SIGNAL_TP=12.0
TAKE_PROFIT_SELL_PCT=0.45
STRONG_TP_SELL_PCT=0.60

# --- USDC copy strategy ---
ENABLE_USDC_COPY=true
USDC_COPY_MIN_TRADE=5.0
USDC_COPY_MAX_TRADE=15.0
COPY_BASE_EXPECTED_EDGE_PCT=6.0
COPY_GAS_EDGE_MULTIPLIER=2.5
COPY_MIN_EFFECTIVE_TRADE_AFTER_GAS_USD=10.0
COPY_MIN_MARGINAL_TRADE_USD=12.0
COPY_WALLET_PERFORMANCE_FILE=wallet_performance.json
COPY_WALLET_PERFORMANCE_WINDOW_TRADES=25
COPY_WALLET_PERFORMANCE_MIN_TRADES=8
COPY_WALLET_PERFORMANCE_POOR_WINRATE=0.40
COPY_WALLET_PERFORMANCE_POOR_AVG_PNL_USD=-0.20
COPY_WALLET_PERFORMANCE_PENALTY_MULTIPLIER=0.65

# --- X-Signal equity ---
ENABLE_X_SIGNAL_EQUITY=true
FOLLOWED_EQUITIES_PATH=followed_equities.json
X_SIGNAL_EQUITY_MIN_STRENGTH=0.60
X_SIGNAL_STRONG_THRESHOLD=0.80
# Optional compatibility alias used by config fallback:
# if set, this seeds X_SIGNAL_* high-conviction thresholds.
HIGH_CONVICTION_THRESHOLD=0.80
X_SIGNAL_MAX_EARNINGS_DAYS=5.0
X_SIGNAL_FORCE_ELIGIBLE_THRESHOLD=0.80
X_SIGNAL_FORCE_HIGH_CONVICTION_THRESHOLD=0.80
X_SIGNAL_FORCE_HIGH_CONVICTION=true
X_SIGNAL_HIGH_CONVICTION_PREP_MIN_USDC=8.0
X_SIGNAL_HIGH_CONVICTION_PREP_MIN_WMATIC=12.0
X_SIGNAL_DYNAMIC_TIER_HIGH_MIN=0.90
X_SIGNAL_DYNAMIC_USDC_GTE_TIER_HIGH=20.0
X_SIGNAL_DYNAMIC_USDC_GTE_FORCE_ELIGIBLE=15.0
X_SIGNAL_DYNAMIC_USDC_BELOW_FORCE_ELIGIBLE=12.0
X_SIGNAL_EQUITY_COOLDOWN_FIRST_SORT=true
X_SIGNAL_EQUITY_COOLDOWN_SECONDS=
X_SIGNAL_EQUITY_STRONG_TP_PCT=12.0
X_SIGNAL_EQUITY_SELL_FRACTION=0.55
X_SIGNAL_EQUITY_TRADE_PCT=0.18
X_SIGNAL_EQUITY_MAX_TRADE=28.0
X_SIGNAL_EQUITY_MIN_TRADE=
X_SIGNAL_USDC_MIN=5.0
X_SIGNAL_WMATIC_MIN_VALUE=15.0
AUTO_POPULATE_USDC_AMOUNT=20.0
AUTO_USDC_FOR_X_SIGNAL_MIN_USDC=5.0
AUTO_USDC_FOR_X_SIGNAL_MIN_WMATIC_VALUE=15.0
X_SIGNAL_USDC_SAFE_FLOOR=20.0
X_SIGNAL_AUTO_USDC_TARGET=25.0
X_SIGNAL_AUTO_USDC_TOPUP_ENABLED=true
X_SIGNAL_AUTO_USDC_MIN_SWAP_USD=8.0
# On-chain USDC read retries per balance query cycle (minimum effective attempts = 2).
X_SIGNAL_ONCHAIN_USDC_RETRY_ATTEMPTS=2

# --- Swaps ---
# IMPORTANT: slippage is in basis points (bps), not percent.
# Example: 0.8% = 80 bps.
SWAP_SLIPPAGE_BPS=100
FALLBACK_ROUTER_SLIPPAGE_BPS=
FALLBACK_ROUTER_RETRY_SLIPPAGE_BPS=
ONCHAIN_SWAP_RETRY_EXTRA_BPS=50
# 1inch endpoints are optional advanced overrides.
ONEINCH_SWAP_ENDPOINT=https://api.1inch.dev/swap/v5.2/137/swap
ONEINCH_SPENDER_ENDPOINT=https://api.1inch.dev/swap/v5.2/137/approve/spender
# Stage VM compatibility names (also read by config.py):
HIGH_CONVICTION_FALLBACK_PRIMARY_BPS=3500
HIGH_CONVICTION_FALLBACK_RETRY_BPS=4500
HIGH_CONVICTION_FALLBACK_SLIPPAGE_BPS=
HIGH_CONVICTION_FALLBACK_RETRY_SLIPPAGE_BPS=

# --- Logging hooks ---
NANOCLAW_TRADE_ATTRIBUTION=true
NO_COLOR=
NANOCLAW_AGENT_LAYER_ENABLED=false
NANOCLAW_TELEMETRY_TELEGRAM=false
NANOCLAW_AGENT_CAN_OVERRIDE_SWAP=false
NANOCLAW_AGENT_LAYER_ADVISORY=false

# --- ROI / PnL baseline (nanostatus/nanopnl, modules/baseline.py) ---
# 0 = automatic (same as empty): portfolio_baseline.json → CSV first row → live total.
# Set a positive USD value only to pin “starting capital” for return % labels.
PORTFOLIO_BASELINE_USD=0

# --- Safe VM update flow (scripts/nanoup.sh) ---
# 0 (default): fail fast on dirty tree before pull.
# 1: auto-stash local changes, pull fast-forward, then apply stash.
NANOUP_AUTOSTASH=0

# =============================================================================
# Append new non-secret tuning here (agents / brainstorm).
# =============================================================================

# --- Fixed per-signal USD band (runtime.fixed_copy_trade_usd + X-signal dynamic interpolate) ---
# Global hard minimum notional for stable-in BUY legs (execution guard).
# SignalEquityTrader also uses this for hard bypass (skip BUY plans below this USD amount).
MIN_TRADE_USD=15
# Legacy alias still read as fallback only when MIN_TRADE_USD is unset.
# Empty value is safe (config falls back to default).
MIN_TRADE_USDC=15
FIXED_TRADE_USD_MIN=6.5
FIXED_TRADE_USD_MAX=10

# Post 4 May 2026 hardening
HARD_BYPASS_ENABLED=true

# --- Compatibility mapping (to avoid silent no-op keys) ---
# These legacy names are READ:
# - MIN_TRADE_USDC -> fallback for MIN_TRADE_USD
# - HIGH_CONVICTION_FALLBACK_SLIPPAGE_BPS -> fallback for HIGH_CONVICTION_FALLBACK_PRIMARY_BPS
# - HIGH_CONVICTION_FALLBACK_RETRY_SLIPPAGE_BPS -> fallback for HIGH_CONVICTION_FALLBACK_RETRY_BPS
#
# These names are NOT read by code (do not rely on them):
# - FLUCTUATION_THRESHOLD      (use PROTECTION_FLUCTUATION_USDT_THRESHOLD)
# - PROTECTION_COOLDOWN_MIN    (use PROTECTION_FLUCTUATION_COOLDOWN_SECONDS)
# - SLIPPAGE_TOLERANCE         (use SWAP_SLIPPAGE_BPS)
# - MAX_TRADES_PER_HOUR        (not implemented; use cooldown controls)

# --- WMATIC↔USDT main strategy (modules.swap_executor.select_main_strategy_trade) ---
MAIN_STRATEGY_MIN_USDT_RESERVE=25
MAIN_STRATEGY_TP_TRIGGER_WMATIC_USD=52
MAIN_STRATEGY_CUT_LOSS_WMATIC_USD=40
MAIN_STRATEGY_CUT_LOSS_MIN_WMATIC_BALANCE=50
MAIN_STRATEGY_RESERVE_SELL_FRACTION=0.45
MAIN_STRATEGY_CUT_LOSS_SELL_FRACTION=0.28

# --- Aggressive copy-trade banner when COPY_TRADE_PCT is high ---
COPY_TRADE_AGGRESSIVE_THRESHOLD=0.20

# --- protection.py (no wallet secrets) ---
PROTECTION_MAX_DAILY_LOSS_PCT=15
PROTECTION_MIN_POL_BALANCE=2.0
PROTECTION_MAX_TRADE_SIZE_USD=35
PROTECTION_GAS_MULTIPLIER=1.25
PROTECTION_FLUCTUATION_USDT_THRESHOLD=30
PROTECTION_FLUCTUATION_MIN_WMATIC=50
PROTECTION_FLUCTUATION_SELL_FRACTION=0.25
PROTECTION_FLUCTUATION_COOLDOWN_SECONDS=1800
PROTECTION_FLUCTUATION_MIN_SELL_USD=8
PROTECTION_PROFIT_LOCK_PERCENT=8

# --- copy_trading.py default when followed_wallets.json is missing ---
DEFAULT_MAX_COPY_RATIO=0.20

# --- Optional: comma-separated addresses for wrong-chain hints in diagnostics (modules.signal) ---
CHAIN_HINT_WRONG_ETH_ADDRESSES=

# --- Optional tokenized-equity placeholders ---
GOOGLON=
MSFTON=
APPLON=
AMZNON=
