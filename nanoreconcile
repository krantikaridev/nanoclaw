#!/bin/bash
echo "=== NanoReconcile v2.9 (Polygon-only, Polygonscan API) ==="
WALLET=$(grep '^WALLET=' .env | cut -d= -f2)
echo "Wallet: $WALLET"

# Get on-chain USDC balance via Polygonscan (free, reliable)
curl -s "https://api.polygonscan.com/api?module=account&action=tokenbalance&contractaddress=0x2791bca1f2de4661ed88a30c99a7a9449aa84174&address=$WALLET&tag=latest" | python3 -c '
import sys, json
data = json.load(sys.stdin)
result = data.get("result", "0")
print("On-chain USDC:", round(int(result) / 1000000, 2))
' 2>/dev/null || echo "curl call failed"

echo ""
echo "Runtime USDC from nanopnl:"
nanopnl | grep -oE "USDC: ?\$?[0-9.]+" | head -1
echo ""
echo "Done. Run daily (or add to nanohealth later)."
