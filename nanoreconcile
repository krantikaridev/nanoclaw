#!/bin/bash
echo "=== NanoReconcile v2.9 (Polygon-only, automatic) ==="
WALLET=$(grep '^WALLET=' .env | cut -d= -f2)
echo "Wallet: $WALLET"

ANKR_KEY=$(grep '^ANKR_RPC_KEY=' .env | cut -d= -f2- | tr -d '"')
RPC="https://rpc.ankr.com/polygon/${ANKR_KEY}"

get_balance() {
    local token=$1
    local ADDR_PADDED=$(printf '%064s' "${WALLET#0x}" | tr ' ' '0')
    local DATA="0x70a08231${ADDR_PADDED}"
    curl -s -X POST -H "Content-Type: application/json" \
      --data "{\"jsonrpc\":\"2.0\",\"method\":\"eth_call\",\"params\":[{\"to\":\"$token\",\"data\":\"$DATA\"},\"latest\"],\"id\":1}" \
      "$RPC" | python3 -c '
import sys, json
try:
    r = json.load(sys.stdin)
    print(int(r.get("result", "0x0"), 16) / 1_000_000)
except:
    print("ERR")
'
}

USDC_ON=$(get_balance "0x2791bca1f2de4661ed88a30c99a7a9449aa84174")
USDT_ON=$(get_balance "0xc2132d05d31c914a87c6611c10748aeb04b58e8f")

USDC_RT=$(nanopnl | grep -oE "USDC: ?\$?[0-9.]+" | head -1 | grep -oE "[0-9.]+$" || echo "0")
USDT_RT=$(nanopnl | grep -oE "USDT: ?\$?[0-9.]+" | head -1 | grep -oE "[0-9.]+$" || echo "0")

echo ""
printf "On-chain USDC: %8.2f    Runtime: %8.2f    Δ: %+7.2f\n" "$USDC_ON" "$USDC_RT" "$(echo "$USDC_ON - $USDC_RT" | bc -l 2>/dev/null || echo 0)"
printf "On-chain USDT: %8.2f    Runtime: %8.2f    Δ: %+7.2f\n" "$USDT_ON" "$USDT_RT" "$(echo "$USDT_ON - $USDT_RT" | bc -l 2>/dev/null || echo 0)"

echo ""
if (( $(echo "$USDC_ON < 8" | bc -l 2>/dev/null || echo 0) )); then
    echo "⚠️  WARNING: On-chain USDC is low (< 8)"
fi
if (( $(echo "$USDT_ON < 15" | bc -l 2>/dev/null || echo 0) )); then
    echo "⚠️  WARNING: On-chain USDT is low (< 15)"
fi

echo ""
echo "Done. Run daily."
