#!/bin/bash
echo "=== NanoReconcile v2.9 (Polygon-only, automatic) ==="
WALLET=$(grep '^WALLET=' .env | cut -d= -f2)

USDT_TH=$(grep '^PROTECTION_FLUCTUATION_USDT_THRESHOLD=' .env | cut -d= -f2 || echo "12")
WMATIC_TH=$(grep '^PROTECTION_FLUCTUATION_MIN_WMATIC=' .env | cut -d= -f2 || echo "200")

ANKR_KEY=$(grep '^ANKR_RPC_KEY=' .env | cut -d= -f2- | tr -d '"')
RPC="https://rpc.ankr.com/polygon/${ANKR_KEY}"

get_balance() {
    local token=$1
    local decimals=$2
    local ADDR_PADDED=$(printf '%064s' "${WALLET#0x}" | tr ' ' '0')
    local DATA="0x70a08231${ADDR_PADDED}"
    curl -s -X POST -H "Content-Type: application/json" \
      --data "{\"jsonrpc\":\"2.0\",\"method\":\"eth_call\",\"params\":[{\"to\":\"$token\",\"data\":\"$DATA\"},\"latest\"],\"id\":1}" \
      "$RPC" | python3 -c '
import sys, json
try:
    r = json.load(sys.stdin)
    print(int(r.get("result", "0x0"), 16) / '$decimals')
except:
    print("ERR")
'
}

USDC_ON=$(get_balance "0x2791bca1f2de4661ed88a30c99a7a9449aa84174" 1000000)
USDT_ON=$(get_balance "0xc2132d05d31c914a87c6611c10748aeb04b58e8f" 1000000)
WMATIC_ON=$(get_balance "0x0d500b1d8e8ef31e21c99d1db9a6444d3adf1270" 1000000000000000000)
POL_ON=$(get_balance "0x0000000000000000000000000000000000001010" 1000000000000000000)

USDC_RT=$(nanopnl | awk '/USDC:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")
USDT_RT=$(nanopnl | awk '/USDT:/ {gsub(/[$ ]/, "", $2); print $2; exit}' || echo "0")

echo ""
echo "Protection thresholds: USDT < \$$USDT_TH | WMATIC > $WMATIC_TH"
echo ""

USDT_DIFF=$(echo "$USDT_RT - $USDT_ON" | bc -l 2>/dev/null || echo "0")

# Always show significant divergence
if (( $(echo "$USDT_DIFF > 8" | bc -l 2>/dev/null || echo 0) )); then
    printf "⚠️  WARNING: Large USDT divergence detected (%.2f)\n" "$USDT_DIFF"
    echo "   On-chain USDT is significantly lower than runtime value"
fi

# Critical protection zone
if (( $(echo "$USDT_ON < $USDT_TH" | bc -l 2>/dev/null || echo 0) )); then
    echo "🚨 CRITICAL: On-chain USDT below protection threshold (< \$$USDT_TH)"
elif (( $(echo "$USDT_ON < ($USDT_TH + 5)" | bc -l 2>/dev/null || echo 0) )); then
    echo "⚠️  WARNING: On-chain USDT approaching protection threshold"
fi

# Overall risk assessment
if (( $(echo "$USDT_ON < $USDT_TH" | bc -l 2>/dev/null || echo 0) )); then
    echo "🚨 Overall Risk: High — protection likely soon"
elif (( $(echo "$USDT_DIFF > 10" | bc -l 2>/dev/null || echo 0) )); then
    echo "⚠️  Overall Risk: Medium-High — elevated protection risk"
else
    echo "✅ Risk level: Low"
fi

echo ""
DELTA_USDC=$(awk -v a="$USDC_ON" -v b="$USDC_RT" 'BEGIN {printf "%.2f", a-b}')
DELTA_USDT=$(awk -v a="$USDT_ON" -v b="$USDT_RT" 'BEGIN {printf "%.2f", a-b}')

printf "On-chain USDC:   %8.2f    Runtime: %8.2f    Δ: %+7.2f\n" "$USDC_ON" "$USDC_RT" "$DELTA_USDC"
printf "On-chain USDT:   %8.2f    Runtime: %8.2f    Δ: %+7.2f\n" "$USDT_ON" "$USDT_RT" "$DELTA_USDT"
printf "On-chain WMATIC: %12.4f qty\n" "$WMATIC_ON"
printf "On-chain POL:    %12.4f qty\n" "$POL_ON"

echo ""
echo "Done. Run daily."
